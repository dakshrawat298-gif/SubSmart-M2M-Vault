# ─────────────────────────────────────────────────────────────────────────────
# SubSmart Agentic Vault — Environment Configuration
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Agent Economics ───────────────────────────────────────────────────────────
# The buyer's maximum budget ceiling (USDC)
BUYER_BUDGET=100

# The price the buyer is aiming for (USDC)
BUYER_TARGET_PRICE=60

# The seller's opening asking price (USDC)
SELLER_ASKING_PRICE=100

# The seller's absolute floor — will not go below this (USDC)
SELLER_MINIMUM_PRICE=80

# ── Solana Wallets ────────────────────────────────────────────────────────────
# The seller's Devnet wallet address (Base58 public key)
# The buyer's WDK wallet will send USDC to this address on deal confirmation.
SELLER_WALLET_ADDRESS=YourSellerDevnetWalletAddressHere

# The buyer's Devnet private key (Base58 — used by WDK to sign transactions)
# Generate a Devnet keypair: https://docs.solana.com/cli/conventions#keypair-generation
# Fund it with Devnet SOL: https://faucet.solana.com
# Fund it with Devnet USDC: https://spl-token-faucet.com
BUYER_PRIVATE_KEY=YourBuyerDevnetPrivateKeyBase58Here

# ── Tether QVAC (optional) ───────────────────────────────────────────────────
# Path to a GGUF model file for real local LLM inference via QVAC SDK.
# If unset, the built-in deterministic mock is used (great for demos).
# Download a compatible model: https://qvac.tether.io/models
QVAC_MODEL_PATH=./models/llama-3.1-8b.gguf

# ── Solana Network ────────────────────────────────────────────────────────────
# "devnet" for testing | "mainnet-beta" for production
SOLANA_NETWORK=devnet

# Optional: custom Solana RPC endpoint (defaults to public Devnet if unset)
# SOLANA_RPC_URL=https://api.devnet.solana.com
